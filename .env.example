# URL of your (external) PocketBase instance. Baked into the frontend at build
# time — used by `npm run dev` locally AND by `docker compose build`.
VITE_POCKETBASE_URL=http://100.111.93.26:8090

# Host port the dockerized app is served on (http://localhost:<WEB_PORT>).
# docker-compose only; defaults to 8080.
WEB_PORT=8080
